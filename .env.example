# TypeDB Configuration (3.x)
# For local TypeDB Core:
#   TYPEDB_ADDRESS=localhost:1729
#   TYPEDB_TLS_ENABLED=false
# For TypeDB Cloud:
#   TYPEDB_ADDRESS=https://your-cluster.cluster.typedb.com:80
#   TYPEDB_TLS_ENABLED=true
TYPEDB_ADDRESS=localhost:1729
TYPEDB_DATABASE=context_graph
TYPEDB_USERNAME=admin
TYPEDB_PASSWORD=password
TYPEDB_TLS_ENABLED=false
# TYPEDB_TLS_ROOT_CA=/path/to/ca-cert.pem

# LLM Providers
LLM_ANTHROPIC_API_KEY=sk-ant-...
LLM_OPENAI_API_KEY=sk-...
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514

# Connectors (optional)
CONNECTOR_SALESFORCE_USERNAME=
CONNECTOR_SALESFORCE_PASSWORD=
CONNECTOR_SALESFORCE_TOKEN=
CONNECTOR_SLACK_BOT_TOKEN=xoxb-...
CONNECTOR_PAGERDUTY_API_KEY=

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Authentication (leave empty for dev mode - no auth required)
API_KEY=

# Rate Limiting
API_RATE_LIMIT_RPM=120

# Logging (text or json)
LOG_FORMAT=text
LOG_LEVEL=INFO
